      "ease-out": "cubic-bezier(0.2,0,0,1)",
      "dur-fast": "100ms",
      "dur-mid": "160ms",
      "dur-slow": "240ms",
      "leading-tight": "1.2",
      "leading-snug": "1.4",
      "leading-normal": "1.6",
      "leading-loose": "1.7",
      "tracking-tight": "-0.01em",
      "tracking-wide": "0.02em",
      "tracking-label": "0.1em",
      "tracking-caps": "0.14em",
      "radius": "0.25rem"
    },
    "dark": {
      "background": "#0a0c0d",
