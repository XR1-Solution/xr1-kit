  "name": "xr1",
  "homepage": "https://xr1.solutions",
  "items": [
    {
      "name": "xr1-theme",
      "type": "registry:theme",
      "title": "XR1 Theme",
      "description": "XR1 Solution design tokens, fonts, base styles and the terminal cursor keyframes.",
      "cssVars": {
        "theme": {
          "font-display": "'Pixelify Sans', ui-sans-serif, system-ui, sans-serif",
          "font-mono": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
          "font-pixel": "'Silkscreen', 'JetBrains Mono', monospace",
          "radius-sm": "2px",
          "radius-md": "4px",
          "radius-lg": "8px"
        },
        "light": {
          "background": "#0a0c0d", "foreground": "#d7dfdd",
          "card": "#0f1213", "card-foreground": "#d7dfdd",
          "popover": "#161a1b", "popover-foreground": "#d7dfdd",
          "primary": "#6ee7a0", "primary-foreground": "#04130a",
          "secondary": "#161a1b", "secondary-foreground": "#d7dfdd",
          "muted": "#161a1b", "muted-foreground": "#5c6665",
          "accent": "#1e2324", "accent-foreground": "#f2f7f6",
          "destructive": "#f2706e", "destructive-foreground": "#04130a",
          "border": "#242b2c", "input": "#242b2c", "ring": "#6ee7a0",
          "xr1-glow-green": "rgba(110,231,160,0.22)", "xr1-accent-fg": "#04130a",
          "bg-0": "#0a0c0d", "bg-1": "#0f1213", "bg-2": "#161a1b", "bg-3": "#1e2324", "bg-inset": "#070809",
